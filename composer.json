{
    "name": "mage2kishan/module-redirects",
    "description": "Redirects and 404 management for Magento 2 (Hyva + Luma). Manual + auto redirects, bulk CSV import/export, scheduled cleanup, 404 logging and cluster analysis for redirect recommendations. Extracted from Panth_AdvancedSEO for independent installation.",
    "type": "magento2-module",
    "version": "1.0.2",
    "license": "proprietary",
    "keywords": [
        "magento2",
        "magento2-module",
        "panth",
        "redirects",
        "301-redirects",
        "404-logger",
        "url-redirect",
        "hyva",
        "luma",
        "seo"
    ],
    "require": {
        "php": "~8.1.0||~8.2.0||~8.3.0||~8.4.0",
        "magento/framework": "^103.0",
        "magento/module-store": "^101.0",
        "magento/module-backend": "^102.0",
        "magento/module-catalog": "^104.0",
        "magento/module-cms": "^104.0",
        "magento/module-url-rewrite": "^102.0",
        "mage2kishan/module-core": "^1.0"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Panth\\Redirects\\": ""
        }
    }
}

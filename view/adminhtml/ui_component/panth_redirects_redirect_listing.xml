<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_redirects_redirect_listing.panth_redirects_redirect_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_redirects_redirect_listing_columns</spinner>
        <deps>
            <dep>panth_redirects_redirect_listing.panth_redirects_redirect_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/edit"/>
                <class>primary</class>
                <label translate="true">Add Redirect</label>
            </button>
            <button name="import">
                <url path="*/*/importPage"/>
                <label translate="true">Import CSV</label>
            </button>
            <button name="export">
                <url path="*/*/export"/>
                <label translate="true">Export CSV</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="panth_redirects_redirect_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">redirect_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="panth_redirects_redirect_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>redirect_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_redirects_redirect_listing_columns">
        <column name="redirect_id">
            <settings>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
                <filter>textRange</filter>
            </settings>
        </column>
        <column name="pattern">
            <settings>
                <label translate="true">Pattern</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="target">
            <settings>
                <label translate="true">Target</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="match_type">
            <settings>
                <label translate="true">Match Type</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="status_code" class="Panth\Redirects\Ui\Component\Listing\Column\StatusCodeColumn">
            <settings>
                <label translate="true">Status Code</label>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <label translate="true">Active</label>
                <filter>select</filter>
                <dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
            </settings>
        </column>
        <column name="hit_count">
            <settings>
                <label translate="true">Hits</label>
                <filter>textRange</filter>
            </settings>
        </column>
        <column name="start_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <label translate="true">Active From</label>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <visible>true</visible>
            </settings>
        </column>
        <column name="finish_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <label translate="true">Active Until</label>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <visible>true</visible>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\Redirects\Ui\Component\Listing\Column\RedirectActions">
            <settings><indexField>redirect_id</indexField></settings>
        </actionsColumn>
    </columns>
</listing>

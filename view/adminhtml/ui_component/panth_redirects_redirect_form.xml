<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_redirects_redirect_form.panth_redirects_redirect_form_data_source</item>
        </item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="delete" class="Panth\Redirects\Block\Adminhtml\GenericDeleteButton"/>
            <button name="save_and_continue" class="Panth\Redirects\Block\Adminhtml\GenericSaveAndContinueButton"/>
            <button name="save" class="Panth\Redirects\Block\Adminhtml\GenericSaveButton"/>
            <button name="back" class="Panth\Redirects\Block\Adminhtml\GenericBackButton"/>
        </buttons>
        <namespace>panth_redirects_redirect_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>panth_redirects_redirect_form.panth_redirects_redirect_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="panth_redirects_redirect_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="panth_redirects/redirect/save"/>
        </settings>
        <dataProvider class="Panth\Redirects\Ui\Component\Form\DataProvider\RedirectFormDataProvider"
                      name="panth_redirects_redirect_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>redirect_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">General</label>
        </settings>
        <field name="redirect_id" formElement="input">
            <settings>
                <visible>false</visible>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="pattern" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Request Path (Pattern)</label>
                <dataScope>pattern</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">The URL path to match (e.g. /old-page.html). For regex match type, use a regular expression.</notice>
            </settings>
        </field>
        <field name="target" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Target URL</label>
                <dataScope>target</dataScope>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">The destination URL to redirect to.</notice>
            </settings>
        </field>
        <field name="status_code" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Redirect Type</label>
                <dataScope>status_code</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="301" xsi:type="array">
                                <item name="value" xsi:type="number">301</item>
                                <item name="label" xsi:type="string" translate="true">301 (Permanent)</item>
                            </option>
                            <option name="302" xsi:type="array">
                                <item name="value" xsi:type="number">302</item>
                                <item name="label" xsi:type="string" translate="true">302 (Temporary)</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="match_type" formElement="select">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Match Type</label>
                <dataScope>match_type</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options>
                            <option name="literal" xsi:type="array">
                                <item name="value" xsi:type="string">literal</item>
                                <item name="label" xsi:type="string" translate="true">Literal</item>
                            </option>
                            <option name="regex" xsi:type="array">
                                <item name="value" xsi:type="string">regex</item>
                                <item name="label" xsi:type="string" translate="true">Regex</item>
                            </option>
                            <option name="maintenance" xsi:type="array">
                                <item name="value" xsi:type="string">maintenance</item>
                                <item name="label" xsi:type="string" translate="true">Maintenance</item>
                            </option>
                        </options>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="store_id" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Store View</label>
                <dataScope>store_id</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Store\Model\System\Store"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="is_active" formElement="select">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Active</label>
                <dataScope>is_active</dataScope>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="Magento\Config\Model\Config\Source\Yesno"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="priority" formElement="input">
            <settings>
                <dataType>number</dataType>
                <label translate="true">Priority</label>
                <dataScope>priority</dataScope>
                <validation>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
                <notice translate="true">Lower numbers = higher priority. Default is 10.</notice>
            </settings>
        </field>
        <field name="start_at" formElement="date">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Active From</label>
                <dataScope>start_at</dataScope>
                <notice translate="true">Leave empty for no start date restriction.</notice>
            </settings>
            <formElements>
                <date>
                    <settings>
                        <options>
                            <option name="dateFormat" xsi:type="string">yyyy-MM-dd</option>
                            <option name="timeFormat" xsi:type="string">HH:mm:ss</option>
                            <option name="showsTime" xsi:type="boolean">true</option>
                        </options>
                    </settings>
                </date>
            </formElements>
        </field>
        <field name="finish_at" formElement="date">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Active Until</label>
                <dataScope>finish_at</dataScope>
                <notice translate="true">Leave empty for no end date restriction.</notice>
            </settings>
            <formElements>
                <date>
                    <settings>
                        <options>
                            <option name="dateFormat" xsi:type="string">yyyy-MM-dd</option>
                            <option name="timeFormat" xsi:type="string">HH:mm:ss</option>
                            <option name="showsTime" xsi:type="boolean">true</option>
                        </options>
                    </settings>
                </date>
            </formElements>
        </field>
    </fieldset>
</form>

<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="panth_redirects_redirect_cleanup"
             instance="Panth\Redirects\Cron\RedirectCleanup"
             method="execute">
            <schedule>0 4 * * *</schedule>
        </job>
        <job name="panth_redirects_404_cluster"
             instance="Panth\Redirects\Cron\NotFoundCluster"
             method="execute">
            <schedule>0 4 * * *</schedule>
        </job>
    </group>
</config>
